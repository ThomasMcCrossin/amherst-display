# Repo-local Amherst data/highlight env.
# You can also keep Drive settings in a generated state file and point to it with HIGHLIGHTS_ENV_FILE.

# HockeyTech data build inputs.
HOCKEYTECH_API_KEY=
HOCKEYTECH_SEASON_IDS=41,44
HOCKEYTECH_SEASON_LABEL=2025-26
RAMBLERS_ICS_URL=

# Optional explicit path to a generated state env file.
HIGHLIGHTS_ENV_FILE=

# Google Shared Drive / service account.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/hockey-highlight-generator.json
AUTO_UPLOAD_GAME_ARCHIVES_TO_DRIVE=1

HIGHLIGHTS_DRIVE_ID=
HIGHLIGHTS_INGEST_FOLDER_ID=
HIGHLIGHTS_INGEST_FOLDER_PATH=
HIGHLIGHTS_GAMES_FOLDER_ID=
HIGHLIGHTS_GAMES_FOLDER_PATH=
HIGHLIGHTS_REELS_FOLDER_ID=
HIGHLIGHTS_REELS_FOLDER_PATH=
HIGHLIGHTS_MAJOR_REVIEW_FOLDER_ID=
HIGHLIGHTS_MAJOR_REVIEW_FOLDER_PATH=
HIGHLIGHTS_REFERENCE_FOLDER_ID=
HIGHLIGHTS_REFERENCE_FOLDER_PATH=

HIGHLIGHTS_PROGRAM_LEAGUE=MHL
HIGHLIGHTS_PROGRAM_TEAM=Amherst Ramblers
HIGHLIGHTS_PROGRAM_SEASON=2025-26
HIGHLIGHTS_PROGRAM_ROOT_PATH=Programs/MHL/Amherst Ramblers/2025-26

# Optional review email notifications.
RESEND_API_KEY=
NOTIFICATION_EMAIL=
NOTIFICATION_EMAIL_FROM=
